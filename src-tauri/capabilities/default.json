{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:read-files",
    "fs:write-files",
    "fs:scope-home-recursive",
    "fs:scope-document-recursive",
    "fs:scope-desktop-recursive",
    "fs:scope-download-recursive",
    "shell:allow-open"
  ]
}